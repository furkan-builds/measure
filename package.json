{
	"name": "measure",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "turbo dev",
		"dev:web": "turbo dev --filter=@measure/web",
		"dev:api": "turbo dev --filter=@measure/api",
		"dev:mobile": "turbo dev --filter=@measure/mobile",
		"build": "turbo build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "turbo test",
		"test:web": "turbo test --filter=@measure/web",
		"test:api": "turbo test --filter=@measure/api",
		"test:mobile": "turbo test --filter=@measure/mobile",
		"test:shared": "turbo test --filter=@measure/shared",
		"test:database": "turbo test --filter=@measure/database",
		"test:ui": "turbo test --filter=@measure/ui",
		"typecheck": "turbo typecheck",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^25.5.0",
		"husky": "^9.1.7",
		"turbo": "^2.4.0",
		"typescript": "^5.7.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["@biomejs/biome", "argon2", "esbuild"]
	}
}
