{
	"info": {
		"name": "Measure API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3001/api/trpc"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Sign Up",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"name\": \"Test User\",\n\t\"email\": \"test@example.com\",\n\t\"password\": \"mypassword123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth.signup",
							"host": ["{{baseUrl}}"],
							"path": ["auth.signup"]
						}
					}
				},
				{
					"name": "Log In",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"email\": \"test@example.com\",\n\t\"password\": \"mypassword123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth.login",
							"host": ["{{baseUrl}}"],
							"path": ["auth.login"]
						}
					}
				},
				{
					"name": "Me",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/auth.me",
							"host": ["{{baseUrl}}"],
							"path": ["auth.me"]
						}
					}
				},
				{
					"name": "Log Out",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/auth.logout",
							"host": ["{{baseUrl}}"],
							"path": ["auth.logout"]
						}
					}
				},
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/health.check",
							"host": ["{{baseUrl}}"],
							"path": ["health.check"]
						}
					}
				}
			]
		},
		{
			"name": "Food",
			"item": [
				{
					"name": "Create Food",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"name\": \"Banana\",\n\t\"brand\": \"Generic\",\n\t\"caloriesPer100g\": 89,\n\t\"proteinPer100g\": 1.1,\n\t\"carbsPer100g\": 22.8,\n\t\"fatPer100g\": 0.3,\n\t\"fiberPer100g\": 2.6\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/food.create",
							"host": ["{{baseUrl}}"],
							"path": ["food.create"]
						}
					}
				},
				{
					"name": "List Foods",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/food.list",
							"host": ["{{baseUrl}}"],
							"path": ["food.list"]
						}
					}
				}
			]
		},
		{
			"name": "Food Log",
			"item": [
				{
					"name": "Quick Add",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"label\": \"Afternoon snack\",\n\t\"calories\": 350,\n\t\"protein\": 10,\n\t\"carbs\": 40,\n\t\"fat\": 15,\n\t\"meal\": \"snack\",\n\t\"loggedAt\": \"2026-04-02T14:00:00Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/foodLog.quickAdd",
							"host": ["{{baseUrl}}"],
							"path": ["foodLog.quickAdd"]
						}
					}
				},
				{
					"name": "Log (Detailed)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"foodId\": \"REPLACE_WITH_FOOD_ID\",\n\t\"servingId\": \"REPLACE_WITH_SERVING_ID\",\n\t\"quantity\": 1,\n\t\"meal\": \"lunch\",\n\t\"loggedAt\": \"2026-04-02T12:00:00Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/foodLog.log",
							"host": ["{{baseUrl}}"],
							"path": ["foodLog.log"]
						}
					}
				},
				{
					"name": "Edit Entry",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"id\": \"REPLACE_WITH_ENTRY_ID\",\n\t\"calories\": 400,\n\t\"meal\": \"dinner\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/foodLog.edit",
							"host": ["{{baseUrl}}"],
							"path": ["foodLog.edit"]
						}
					}
				},
				{
					"name": "Remove Entry",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"id\": \"REPLACE_WITH_ENTRY_ID\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/foodLog.remove",
							"host": ["{{baseUrl}}"],
							"path": ["foodLog.remove"]
						}
					}
				},
				{
					"name": "List by Date",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/foodLog.list?input={\"date\":\"2026-04-02\"}",
							"host": ["{{baseUrl}}"],
							"path": ["foodLog.list"],
							"query": [
								{
									"key": "input",
									"value": "{\"date\":\"2026-04-02\"}"
								}
							]
						}
					}
				}
			]
		}
	]
}
